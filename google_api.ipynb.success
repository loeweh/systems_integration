{
 "cells": [
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "6b829a0a",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Installiere das neue Google GenAI SDK\n",
    "!pip install -q -U google-genai"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "2484e932-4e97-4af3-b3ec-b626faee227c",
   "metadata": {},
   "source": [
    "# Hinweis: Das neue SDK nutzt client.models.generate_content.\n",
    "# Parameter wie max_output_tokens werden jetzt in einem config-Objekt übergeben."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "ff5baff7",
   "metadata": {},
   "outputs": [],
   "source": [
    "from google import genai\n",
    "import os"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "d5167455",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Gib hier deinen Google API Key ein: ········\n"
     ]
    }
   ],
   "source": [
    "# Hier deinen Google AI Studio API-Schlüssel einfügen\n",
    "from getpass import getpass\n",
    "GOOGLE_API_KEY = getpass(\"Gib hier deinen Google API Key ein:\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "b2bed088",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Initialisiere den Client mit dem neuen SDK\n",
    "client = genai.Client(api_key=GOOGLE_API_KEY)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "ca1c18f0",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Das Modell wird jetzt direkt beim Aufruf oder als Variable definiert\n",
    "model_id = 'gemini-flash-latest'"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "062debe9",
   "metadata": {},
   "outputs": [],
   "source": [
    "# --- Schritt 1: Definiere deinen Prompt ---\n",
    "prompt_text = \"Fasse den folgenden Text in einem Satz zusammen: Künstliche Intelligenz (KI) ist ein weites Feld der Informatik, das sich mit der Erstellung intelligenter Agenten befasst, d. h. Systemen, die in der Lage sind, zu denken, zu lernen und zu handeln wie Menschen.\""
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "id": "c80078e4",
   "metadata": {},
   "outputs": [],
   "source": [
    "# --- Schritt 2: Generiere eine Antwort mit dem neuen Client ---\n",
    "try:\n",
    "    response = client.models.generate_content(model=model_id, contents=prompt_text)\n",
    "except Exception as e:\n",
    "    print(f\"Ein Fehler ist aufgetreten: {e}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "id": "57bb55b7",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Antwort von Gemini 2.0 Flash:\n",
      "Künstliche Intelligenz ist ein Teilbereich der Informatik, der sich der Entwicklung von Systemen widmet, die menschenähnliche kognitive Fähigkeiten wie Denken, Lernen und Handeln besitzen.\n"
     ]
    }
   ],
   "source": [
    "# --- Schritt 3: Verarbeite und zeige die Antwort an ---\n",
    "try:\n",
    "    print(f\"Antwort von Modell-Version: {response.model_version}\")\n",
    "    print(\"-\" * 30)\n",
    "    print(response.text)\n",
    "except Exception as e:\n",
    "    print(f\"Fehler bei der Anzeige: {e}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 11,
   "id": "6d1751ec",
   "metadata": {},
   "outputs": [],
   "source": [
    "# --- Optional: Weitere Schritte ---\n",
    "prompt_text_2 = \"Schreibe eine kurze Geschichte (ca. 50 Wörter) über eine Katze, die einen Computer benutzt.\""
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 12,
   "id": "84dbd0c4",
   "metadata": {},
   "outputs": [],
   "source": [
    "try:\n",
    "    response_2 = client.models.generate_content(model=model_id, contents=prompt_text_2)\n",
    "except Exception as e:\n",
    "    print(f\"Ein Fehler ist aufgetreten: {e}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 13,
   "id": "a996c7fc",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "\n",
      "Zweite Antwort:\n",
      "Luna sprang auf den Schreibtisch und starrte auf den hellen Bildschirm. Mit ihren Pfoten tippte sie wild auf die Tastatur. Ein kurzes „Miau“ und sie drückte die Enter-Taste. Kurz darauf erhielt ihr Besitzer eine Bestätigung: 100 Dosen Thunfisch waren bestellt. Luna schnurrte zufrieden und legte sich auf die warme Maus.\n"
     ]
    }
   ],
   "source": [
    "try:\n",
    "    print(\"\\nZweite Antwort:\")\n",
    "    print(response_2.text)\n",
    "except Exception as e:\n",
    "    print(f\"Fehler bei der Anzeige: {e}\")"
   ]
  }
 ],
